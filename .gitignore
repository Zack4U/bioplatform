# ===========================================
# BioPlatform - Root Git Ignore
# ===========================================
# Only global rules here. Language/framework-specific
# rules live in each sub-project .gitignore.
# ===========================================

# ===========================================
# Environment Files
# ===========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.secret
secrets/
!.env.example
secrets.env
variables.env

# ===========================================
# IDE / Editors
# ===========================================
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ===========================================
# OS Generated
# ===========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ===========================================
# Docker
# ===========================================
.docker/
.docker_temp/

# ===========================================
# Certificates & Keys
# ===========================================
*.pem
*.key
*.crt
*.p12
*.pfx
docker/nginx/ssl/*
!docker/nginx/ssl/.gitkeep

# ===========================================
# Testing (global)
# ===========================================
coverage/
*.lcov

# ===========================================
# Temporary Files
# ===========================================
*.tmp
*.temp
*.log
*.cache
.cache/
tmp/
temp/

.gemini