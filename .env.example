# ===========================================
# BioPlatform Caldas - Environment Variables
# ===========================================
# Copia este archivo a .env y completa los valores
# NUNCA subas el archivo .env al repositorio

# ===========================================
# GENERAL
# ===========================================
ENVIRONMENT=development
APP_NAME=BioPlatform
APP_VERSION=1.0.0

# ===========================================
# SQL SERVER (Transaccional - Identity, Marketplace, Pagos)
# ===========================================
DB_SQL_SERVER=localhost
DB_SQL_PORT=1433
DB_SQL_DATABASE=BioCommerce_Transactional
DB_SQL_USER=sa
DB_SQL_PASSWORD=YourStrong@Password123

# Connection String completo (para .NET)
DB_CONNECTION_STRING_SQL=Server=localhost,1433;Database=BioCommerce_Transactional;User Id=sa;Password=YourStrong@Password123;TrustServerCertificate=True

# ===========================================
# POSTGRESQL (Científico - Especies, Taxonomía, GIS, AI)
# ===========================================
DB_PG_HOST=localhost
DB_PG_PORT=5432
DB_PG_DATABASE=BioCommerce_Scientific
DB_PG_USER=postgres
DB_PG_PASSWORD=YourStrong@Password123

# Connection String completo (para .NET y Python)
DB_CONNECTION_STRING_PG=Host=localhost;Port=5432;Database=BioCommerce_Scientific;Username=postgres;Password=YourStrong@Password123

# ===========================================
# MONGODB (Logs - Opcional)
# ===========================================
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DATABASE=BioCommerce_Logs
MONGO_USER=mongo
MONGO_PASSWORD=YourStrong@Password123
MONGO_CONNECTION_STRING=mongodb://mongo:YourStrong@Password123@localhost:27017/BioCommerce_Logs

# ===========================================
# REDIS (Caché)
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CONNECTION_STRING=localhost:6379

# ===========================================
# AUTENTICACIÓN JWT
# ===========================================
# Genera un secret seguro: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_64_CHARACTER_SECRET_KEY_GENERATED_WITH_OPENSSL
JWT_ISSUER=bioplatform-api
JWT_AUDIENCE=bioplatform-clients
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=7

# ===========================================
# 2FA - TOTP
# ===========================================
TOTP_ISSUER=BioPlatform
TOTP_DIGITS=6
TOTP_PERIOD=30

# ===========================================
# OPENAI API (RAG & Generative AI)
# ===========================================
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_API_KEY
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ===========================================
# CHROMADB (Vector Store)
# ===========================================
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=bioplatform_species

# ===========================================
# STRIPE (Pasarela de Pagos - Sandbox)
# ===========================================
# Obtener en: https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLIC_KEY=pk_test_REPLACE_WITH_YOUR_KEY
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET

# ===========================================
# AZURE BLOB STORAGE (Imágenes)
# ===========================================
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_STORAGE_CONTAINER_SPECIES=species-images
AZURE_STORAGE_CONTAINER_PRODUCTS=product-images

# Alternativa: AWS S3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=bioplatform-images

# ===========================================
# SERVICIOS INTERNOS (URLs)
# ===========================================
# Backend .NET Core API
API_BASE_URL=http://localhost:5000
API_HTTPS_URL=https://localhost:5001

# Backend AI (FastAPI)
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_INTERNAL_URL=http://ai-service:8000

# Frontend Web
WEB_APP_URL=http://localhost:3000

# ===========================================
# FRONTEND (Variables públicas - NEXT_PUBLIC_)
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_AI_API_URL=http://localhost:8000/api
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_REPLACE_WITH_YOUR_KEY
NEXT_PUBLIC_MAPBOX_TOKEN=pk.REPLACE_WITH_YOUR_MAPBOX_TOKEN

# ===========================================
# LOGGING & MONITORING
# ===========================================
LOG_LEVEL=Information
SERILOG_SEQ_URL=http://localhost:5341
SERILOG_MINIMUM_LEVEL=Debug

# ===========================================
# HERRAMIENTAS DE DESARROLLO (pgAdmin, Seq, etc.)
# ===========================================
# pgAdmin (UI para PostgreSQL)
PGADMIN_DEFAULT_EMAIL=admin@bioplatform.dev
PGADMIN_DEFAULT_PASSWORD=admin123

# Seq (Logging centralizado)
# EMAIL (SMTP) - Para verificación y notificaciones
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=BioPlatform Caldas
SMTP_FROM_EMAIL=noreply@bioplatform.co

# ===========================================
# CORS
# ===========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://bioplatform.co

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# ===========================================
# AI MODEL PATHS
# ===========================================
CNN_MODEL_PATH=./data/models_weights/species_classifier.h5
VECTOR_STORE_PATH=./data/vector_store
