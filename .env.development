# ===========================================
# BioPlatform - DEVELOPMENT Environment
# ===========================================
# Configuración para desarrollo local
# Copiar a .env en la raíz del proyecto

# ===========================================
# GENERAL
# ===========================================
ENVIRONMENT=development
APP_NAME=BioPlatform-Dev
APP_VERSION=1.0.0-dev
LOG_LEVEL=Debug

# ===========================================
# SQL SERVER (Transaccional)
# ===========================================
# Nota: En Docker, el host es "sqlserver" (nombre del servicio)
#       Para conexiones locales (sin Docker), usar "localhost"
DB_SQL_SERVER=sqlserver
DB_SQL_PORT=1433
DB_SQL_DATABASE=BioCommerce_Transactional
DB_SQL_USER=sa
DB_SQL_PASSWORD=DevPassword123!

# Connection String para .NET (dentro de Docker)
DB_CONNECTION_STRING_SQL=Server=sqlserver,1433;Database=BioCommerce_Transactional;User Id=sa;Password=DevPassword123!;TrustServerCertificate=True

# Connection String para herramientas locales (fuera de Docker)
# DB_CONNECTION_STRING_SQL_LOCAL=Server=localhost,1433;Database=BioCommerce_Transactional;User Id=sa;Password=DevPassword123!;TrustServerCertificate=True

# ===========================================
# POSTGRESQL (Científico)
# ===========================================
DB_PG_HOST=postgres
DB_PG_PORT=5432
DB_PG_DATABASE=BioCommerce_Scientific
DB_PG_USER=postgres
DB_PG_PASSWORD=DevPassword123!

# Connection String para .NET/Python (dentro de Docker)
DB_CONNECTION_STRING_PG=Host=postgres;Port=5432;Database=BioCommerce_Scientific;Username=postgres;Password=DevPassword123!

# ===========================================
# MONGODB (Logs - Opcional)
# ===========================================
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DATABASE=BioCommerce_Logs
MONGO_USER=mongo
MONGO_PASSWORD=DevPassword123!
MONGO_CONNECTION_STRING=mongodb://mongo:DevPassword123!@mongodb:27017/BioCommerce_Logs

# ===========================================
# REDIS (Caché)
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CONNECTION_STRING=redis:6379

# ===========================================
# AUTENTICACIÓN JWT (Desarrollo)
# ===========================================
# IMPORTANTE: Cambiar en producción
JWT_SECRET=DEV_SECRET_KEY_DO_NOT_USE_IN_PRODUCTION_12345678901234567890
JWT_ISSUER=bioplatform-dev
JWT_AUDIENCE=bioplatform-clients-dev
JWT_EXPIRATION_MINUTES=1440
JWT_REFRESH_EXPIRATION_DAYS=30

# ===========================================
# 2FA - TOTP
# ===========================================
TOTP_ISSUER=BioPlatform-Dev
TOTP_DIGITS=6
TOTP_PERIOD=30

# ===========================================
# OPENAI API (RAG & Generative AI)
# ===========================================
# Para desarrollo puedes usar una key de prueba o dejar vacío
# El sistema funcionará sin IA hasta que configures una key real
OPENAI_API_KEY=sk-your-development-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ===========================================
# CHROMADB (Vector Store)
# ===========================================
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=bioplatform_species_dev

# ===========================================
# STRIPE (Sandbox - Pagos de prueba)
# ===========================================
# Obtener keys de prueba en: https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLIC_KEY=pk_test_your_test_key_here
STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ===========================================
# AZURE BLOB STORAGE (Imágenes) - Opcional en desarrollo
# ===========================================
# En desarrollo puedes usar almacenamiento local
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_SPECIES=species-images-dev
AZURE_STORAGE_CONTAINER_PRODUCTS=product-images-dev

# ===========================================
# SERVICIOS INTERNOS (URLs Docker)
# ===========================================
# Dentro de Docker, los servicios se comunican por nombre
API_BASE_URL=http://backend-core:5000
AI_SERVICE_URL=http://ai-service:8000
AI_SERVICE_INTERNAL_URL=http://ai-service:8000
WEB_APP_URL=http://frontend-web:3000

# ===========================================
# FRONTEND (Variables públicas)
# ===========================================
# Estas usan localhost porque el browser las accede desde fuera de Docker
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_AI_API_URL=http://localhost:8000/api
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_your_test_key_here
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# ===========================================
# LOGGING & DEBUGGING
# ===========================================
LOG_LEVEL=Debug
SERILOG_SEQ_URL=http://seq:80
SERILOG_MINIMUM_LEVEL=Debug
ASPNETCORE_ENVIRONMENT=Development

# ===========================================
# EMAIL (Desarrollo - usar Mailhog o similar)
# ===========================================
# En desarrollo puedes usar servicios como Mailhog, Mailtrap, o desactivar
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=BioPlatform Dev
SMTP_FROM_EMAIL=dev@bioplatform.local

# ===========================================
# CORS (Permitir orígenes de desarrollo)
# ===========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ===========================================
# RATE LIMITING (Relajado para desarrollo)
# ===========================================
RATE_LIMIT_REQUESTS_PER_MINUTE=1000
RATE_LIMIT_REQUESTS_PER_HOUR=10000

# ===========================================
# AI MODEL PATHS
# ===========================================
CNN_MODEL_PATH=./data/models_weights/species_classifier.h5
VECTOR_STORE_PATH=./data/vector_store
