        <methods>
            <methodStep>
                <description>
                    <para>Se visitaron árboles adultos previamente localizados por el Jardín Botánico de Medellín y la Corporación Autónoma Regional del Centro de Antioquia CORANTIOQUIA. Estos árboles fueron debidamente georreferenciados y visitados mensualmente para observaciones fenológicas.</para>
                </description>
            </methodStep>
            <methodStep>
                <description>
                    <para>Se realizaron observaciones mensuales de estructuras reproductivas: botones florales, flores, frutos verdes y frutos maduros, mediante escalado de árboles</para>
                </description>
            </methodStep>
            <sampling>
