# ===========================================
# BioPlatform AI Service — Environment Variables
# ===========================================
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.

# ── Service ────────────────────────────────────────────────────
APP_NAME=BioPlatform AI Service
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# ── PostgreSQL (BioCommerce_Scientific) ────────────────────────
PG_HOST=localhost
PG_PORT=5433
PG_USER=postgres
PG_PASSWORD=your_secure_password_here
PG_DATABASE=biocommerce_scientific

# ── CNN Model ──────────────────────────────────────────────────
MODEL_WEIGHTS_PATH=data/weights/best_model.pth
BIO_MIN_F1_THRESHOLD=0.65

# ── CORS (comma-separated origins) ────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── OpenAI (for RAG / Business Plans) ─────────────────────────
# OPENAI_API_KEY=sk-...

# ===========================================
# Amazon Web Services
# ===========================================
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1

# ===========================================
# Google AI (for RAG / Business Plans) 
# ===========================================
GOOGLE_AI_API_KEY=your_google_ai_api_key_here