    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "SqlServer": "REPLACE_IN_DEVELOPMENT_JSON",
    "PostgreSql": "REPLACE_IN_DEVELOPMENT_JSON"
  },

