# ===========================================
# BioPlatform - Docker Ignore
# ===========================================

# Git
**/.git
**/.gitignore
**/.gitattributes

# IDE
**/.vscode
**/.idea
**/*.swp
**/*.swo

# Documentation (not needed in containers)
**/.docs
**/README.md
**/*.md
!**/requirements.txt

# Node.js
**/node_modules
**/.next
**/out
**/.expo
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# .NET
**/bin
**/obj
**/TestResults
**/*.user

# Python
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd
**/venv
**/.venv
**/env
**/.pytest_cache
**/.mypy_cache

# AI Models (mount as volumes instead)
**/models_weights/*.h5
**/models_weights/*.pt
**/vector_store
**/chroma_data

# Environment files
**/.env
**/.env.*
!**/.env.example

# Docker files (avoid recursive issues)
**/docker-compose*.yml
**/Dockerfile*
**/.docker

# Testing
**/coverage
**/.nyc_output
**/TestResults

# OS
**/.DS_Store
**/Thumbs.db

# Certificates (mount as volumes)
**/ssl/*.pem
**/ssl/*.key
**/ssl/*.crt

# Misc
**/*.log
**/*.tmp
**/*.temp
**/tmp
**/temp
